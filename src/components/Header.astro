---
import Link from "@components/Link.astro";
---

<header id="site-header" transition:persist>
  <div class="mx-auto header-frame px-4 sm:px-6 md:px-8">
    <div class="header-shell">
      <Link href="/" underline={false}>
        <span class="header-home-link">
          <span class="header-brand-link">
            <span class="header-brand-kicker">AI PRODUCT / PORTFOLIO</span>
            <span class="header-name" style="font-family: var(--font-display); color: var(--color-text-primary);">
              Chris
            </span>
          </span>
        </span>
      </Link>

      <div class="header-divider" aria-hidden="true"></div>

      <div class="header-section-block">
        <span class="header-section-kicker">CURRENT SECTION</span>
        <span
          id="nav-section-label"
          class="header-section-label hidden sm:block"
        ></span>
      </div>
    </div>
  </div>
</header>

<style>
  .header-frame {
    max-width: 72rem;
  }

  .header-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) auto minmax(0, 0.85fr);
    align-items: end;
    gap: clamp(0.85rem, 1.6vw, 1.2rem);
    min-height: 3rem;
    padding: 0.5rem 0 0.38rem;
    border-bottom: 1px solid oklch(0.28 0.02 260 / 0.34);
  }

  .header-home-link {
    text-decoration: none;
  }

  .header-brand-link,
  .header-section-block {
    display: flex;
    flex-direction: column;
    gap: 0.26rem;
    min-width: 0;
    transition: opacity 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header-brand-link {
    text-decoration: none;
  }

  .header-home-link:hover .header-brand-link,
  .header-home-link:focus-visible .header-brand-link {
    opacity: 0.92;
  }

  .header-brand-kicker,
  .header-section-kicker {
    font-size: 0.54rem;
    letter-spacing: 0.22em;
    line-height: 1;
    color: var(--color-text-secondary);
    opacity: 0.54;
  }

  .header-name {
    font-size: clamp(1.12rem, 1rem + 0.42vw, 1.38rem);
    font-weight: 400;
    font-style: normal;
    letter-spacing: 0.03em;
    line-height: 0.95;
    text-wrap: nowrap;
    transform: translateY(0);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header-home-link:hover .header-name,
  .header-home-link:focus-visible .header-name {
    transform: translateY(-2px);
  }

  .header-divider {
    width: 1px;
    min-height: 1.95rem;
    justify-self: center;
    background: linear-gradient(
      to bottom,
      oklch(0.72 0.02 55 / 0),
      oklch(0.72 0.02 55 / 0.22),
      oklch(0.72 0.02 55 / 0)
    );
  }

  .header-section-block {
    align-items: flex-end;
    text-align: right;
    padding-bottom: 0.05rem;
  }

  .header-section-label {
    max-width: 15ch;
    font-size: clamp(0.8rem, 0.72rem + 0.22vw, 0.92rem);
    font-weight: 500;
    letter-spacing: 0.08em;
    line-height: 1;
    text-wrap: balance;
    color: oklch(0.82 0.08 55);
    text-shadow: 0 0 18px oklch(0.75 0.18 55 / 0.04);
    transition: opacity 0.34s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.34s cubic-bezier(0.16, 1, 0.3, 1),
                filter 0.34s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (min-width: 768px) {
    .header-frame {
      padding-left: clamp(2rem, 4vw, 3rem);
      padding-right: clamp(2rem, 4vw, 3rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .header-name,
    .header-section-label {
      transition: none;
    }
  }

  @media (max-width: 639px) {
    .header-shell {
      grid-template-columns: minmax(0, 1fr);
      align-items: start;
      gap: 0.4rem;
      min-height: auto;
      padding: 0.56rem 0 0.34rem;
    }

    .header-name {
      font-size: 1.12rem;
    }

    .header-divider,
    .header-section-block {
      display: none;
    }
  }
</style>

<script>
let headerNavInitialized = false;
let headerNavSwapListenerBound = false;

function initHeaderNav() {
  if (headerNavInitialized) return;

  const label = document.getElementById('nav-section-label');
  if (!label || window.matchMedia('(max-width: 639px)').matches) return;

  const sections = document.querySelectorAll<HTMLElement>('[data-nav-title]');
  if (!sections.length) return;

  headerNavInitialized = true;

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let current = '';
  let updateTimer = 0;

  const setLabel = (title: string) => {
    window.clearTimeout(updateTimer);

    if (prefersReducedMotion) {
      label.textContent = title;
      current = title;
      return;
    }

    label.style.opacity = '0';
    label.style.transform = 'translateY(-5px)';
    label.style.filter = 'blur(3px)';

    updateTimer = window.setTimeout(() => {
      label.textContent = title;
      current = title;
      label.style.opacity = '1';
      label.style.transform = 'translateY(0)';
      label.style.filter = 'blur(0)';
    }, 140);
  };

  const initialSection = Array.from(sections).find((section) => {
    const rect = section.getBoundingClientRect();
    return rect.top <= window.innerHeight * 0.5 && rect.bottom >= window.innerHeight * 0.5;
  }) || sections[0];

  const initialTitle = initialSection?.dataset.navTitle || '';
  if (initialTitle) {
    label.textContent = initialTitle;
    current = initialTitle;
  }

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;
        const el = entry.target as HTMLElement;
        const title = el.dataset.navTitle || '';

        if (title && title !== current) {
          setLabel(title);
        }
      }
    },
    { rootMargin: '-49% 0px -49% 0px', threshold: 0 }
  );

  for (const section of sections) {
    observer.observe(section);
  }

  document.addEventListener('astro:before-swap', () => {
    headerNavInitialized = false;
    observer.disconnect();
    window.clearTimeout(updateTimer);
  }, { once: true });
}

if (!headerNavSwapListenerBound) {
  document.addEventListener('astro:after-swap', initHeaderNav);
  headerNavSwapListenerBound = true;
}

initHeaderNav();
</script>
