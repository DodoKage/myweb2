---
/**
 * PortraitParticles: 照片像素 → 彩色粒子人像
 * 鼠标交互时粒子散开，离开后聚合回人像形状
 */
interface Props {
  src?: string;
  class?: string;
}

const { src = '/avatar.jpg', class: className = '' } = Astro.props;
---

<div class:list={['portrait-particles', className]} data-src={src}>
  <canvas id="portrait-canvas"></canvas>
</div>

<style>
  .portrait-particles {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }
  #portrait-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>

<script>
function initPortraitParticles() {
  const container = document.querySelector('.portrait-particles') as HTMLElement;
  if (!container) return;

  const canvas = document.getElementById('portrait-canvas') as HTMLCanvasElement;
  if (!canvas) return;

  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  const imgSrc = container.dataset.src || '/avatar.jpg';

  let width = 0;
  let height = 0;
  let mouseX = -1000;
  let mouseY = -1000;
  let animId: number | null = null;

  type Particle = {
    x: number;
    y: number;
    targetX: number;
    targetY: number;
    vx: number;
    vy: number;
    r: number;
    g: number;
    b: number;
    size: number;
  };

  let particles: Particle[] = [];
  const img = new Image();
  img.crossOrigin = 'anonymous';

  function resize() {
    const rect = container.getBoundingClientRect();
    width = rect.width;
    height = rect.height;
    const dpr = window.devicePixelRatio || 1;
    canvas.width = width * dpr;
    canvas.height = height * dpr;
    ctx!.scale(dpr, dpr);
    if (img.complete && img.naturalWidth > 0) {
      generateParticles();
    }
  }

  function generateParticles() {
    particles = [];
    const offscreen = document.createElement('canvas');
    const offCtx = offscreen.getContext('2d');
    if (!offCtx) return;

    // Fit image into container maintaining aspect ratio
    const imgAspect = img.naturalWidth / img.naturalHeight;
    const containerAspect = width / height;
    let drawW: number, drawH: number, offsetX: number, offsetY: number;

    if (imgAspect > containerAspect) {
      drawH = height;
      drawW = height * imgAspect;
      offsetX = (width - drawW) / 2;
      offsetY = 0;
    } else {
      drawW = width;
      drawH = width / imgAspect;
      offsetX = 0;
      offsetY = (height - drawH) / 2;
    }

    offscreen.width = width;
    offscreen.height = height;
    offCtx.drawImage(img, offsetX, offsetY, drawW, drawH);

    const imageData = offCtx.getImageData(0, 0, width, height);
    const gap = Math.max(3, Math.floor(Math.min(width, height) / 120));

    for (let y = 0; y < height; y += gap) {
      for (let x = 0; x < width; x += gap) {
        const index = (y * width + x) * 4;
        const r = imageData.data[index]!;
        const g = imageData.data[index + 1]!;
        const b = imageData.data[index + 2]!;
        const a = imageData.data[index + 3]!;

        // Skip transparent or very dark pixels (background)
        if (a < 50) continue;
        const brightness = (r + g + b) / 3;
        if (brightness < 15) continue;

        particles.push({
          x: x + (Math.random() - 0.5) * width * 0.5,
          y: y + (Math.random() - 0.5) * height * 0.5,
          targetX: x,
          targetY: y,
          vx: 0,
          vy: 0,
          r, g, b,
          size: gap * 0.6 + Math.random() * gap * 0.3,
        });
      }
    }
  }

  function render() {
    if (!ctx) return;
    ctx.clearRect(0, 0, width, height);

    const mouseRadius = 60;
    const isDark = document.documentElement.classList.contains('dark');

    for (const p of particles) {
      // Mouse repulsion
      const dx = p.x - mouseX;
      const dy = p.y - mouseY;
      const dist = Math.sqrt(dx * dx + dy * dy);

      if (dist < mouseRadius && dist > 0) {
        const force = (mouseRadius - dist) / mouseRadius;
        p.vx += (dx / dist) * force * 4;
        p.vy += (dy / dist) * force * 4;
      }

      // Spring back to target
      p.vx += (p.targetX - p.x) * 0.06;
      p.vy += (p.targetY - p.y) * 0.06;

      // Damping
      p.vx *= 0.82;
      p.vy *= 0.82;

      // Update position
      p.x += p.vx;
      p.y += p.vy;

      // Draw particle as circle with image color
      let r = p.r, g = p.g, b = p.b;
      if (isDark) {
        // Brighten in dark mode
        r = Math.min(255, r + 40);
        g = Math.min(255, g + 40);
        b = Math.min(255, b + 40);
      }

      ctx.fillStyle = `rgb(${r},${g},${b})`;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size * 0.5, 0, Math.PI * 2);
      ctx.fill();
    }

    animId = requestAnimationFrame(render);
  }

  function onMouseMove(e: MouseEvent) {
    const rect = canvas.getBoundingClientRect();
    mouseX = e.clientX - rect.left;
    mouseY = e.clientY - rect.top;
  }

  function onMouseLeave() {
    mouseX = -1000;
    mouseY = -1000;
  }

  function cleanup() {
    if (animId !== null) cancelAnimationFrame(animId);
    window.removeEventListener('resize', resize);
    canvas.removeEventListener('mousemove', onMouseMove);
    canvas.removeEventListener('mouseleave', onMouseLeave);
  }

  // Setup
  canvas.addEventListener('mousemove', onMouseMove);
  canvas.addEventListener('mouseleave', onMouseLeave);
  window.addEventListener('resize', resize);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  img.onload = () => {
    resize();
    if (!prefersReducedMotion) {
      render();
    } else {
      // Static render for reduced motion
      for (const p of particles) {
        p.x = p.targetX;
        p.y = p.targetY;
      }
      render();
      if (animId !== null) cancelAnimationFrame(animId);
    }
  };
  img.src = imgSrc;

  document.addEventListener('astro:before-swap', cleanup, { once: true });
}

initPortraitParticles();
document.addEventListener('astro:after-swap', initPortraitParticles);
</script>
