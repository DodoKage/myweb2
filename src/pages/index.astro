</style>

<script>
  let landingInitialized = false;
  let landingCleanup: (() => void) | null = null;
  let typewriterCleanup: (() => void) | null = null;

  function initLandingTypewriter(root: HTMLElement) {
    const typewriter = root.querySelector<HTMLElement>('.typewriter');
    if (!typewriter) return () => {};

    const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
    const legacyMotionQuery = motionQuery as MediaQueryList & {
      addListener?: (listener: (event: MediaQueryListEvent) => void) => void;
      removeListener?: (listener: (event: MediaQueryListEvent) => void) => void;
    };
    const rawText = typewriter.dataset.text?.trim() || typewriter.textContent?.trim() || '';
    if (!rawText) return () => {};

    let doneTimer = 0;

    typewriter.textContent = rawText;

    const getPerCharDuration = (value: string) => {
      const hasChinese = /[\u3400-\u9fff]/.test(value);
      return hasChinese ? 0.12 : 0.08;
    };

    const applyMotionState = (reducedMotion: boolean) => {
      window.clearTimeout(doneTimer);
      typewriter.classList.remove('done');

      if (reducedMotion) {
        typewriter.style.removeProperty('--typewriter-duration');
        typewriter.style.removeProperty('--typewriter-steps');
        typewriter.classList.add('done');
        return;
      }

      const chars = Array.from(rawText).length;
      const duration = Math.max(chars * getPerCharDuration(rawText), 0.6);
      typewriter.style.setProperty('--typewriter-duration', `${duration}s`);
      typewriter.style.setProperty('--typewriter-steps', `${Math.max(chars, 1)}`);
    };

    const handleAnimationEnd = (event: AnimationEvent) => {
      if (event.animationName !== 'typewriter-reveal') return;
      window.clearTimeout(doneTimer);
      doneTimer = window.setTimeout(() => {
        typewriter.classList.add('done');
      }, 1000);
    };

    const handleMotionChange = (event: MediaQueryListEvent) => {
      applyMotionState(event.matches);
    };

    applyMotionState(motionQuery.matches);
    typewriter.addEventListener('animationend', handleAnimationEnd);

    if ('addEventListener' in motionQuery) {
      motionQuery.addEventListener('change', handleMotionChange);
    } else {
      legacyMotionQuery.addListener?.(handleMotionChange);
    }

    return () => {
      window.clearTimeout(doneTimer);
      typewriter.removeEventListener('animationend', handleAnimationEnd);
      if ('removeEventListener' in motionQuery) {
        motionQuery.removeEventListener('change', handleMotionChange);
      } else {
        legacyMotionQuery.removeListener?.(handleMotionChange);
      }
    };
  }

  function setLandingHeaderVisibility(isLandingVisible: boolean) {
    const header = document.getElementById('site-header');
    if (!header) return;

    header.classList.toggle('landing-header-hidden', isLandingVisible);
  }

  function createHeroImageShatter(root: HTMLElement) {
    const canvas = root.querySelector<HTMLCanvasElement>('.hero-shatter-canvas');
    if (!canvas) return () => {};

    const context = canvas.getContext('2d');
    if (!context) return () => {};

    const image = root.querySelector<HTMLImageElement>('.landing-portrait');
    if (!image) return () => {};

    const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
    const legacyMotionQuery = motionQuery as MediaQueryList & {
      addListener?: (listener: (event: MediaQueryListEvent) => void) => void;
      removeListener?: (listener: (event: MediaQueryListEvent) => void) => void;
    };

    let reducedMotion = motionQuery.matches;
    let width = 0;
    let height = 0;
    let dpr = 1;
    let edgeBand = 0;
    let animationFrameId = 0;
    let resizeFrameId = 0;
    let idleTimer = 0;
    let pointerInside = false;
    let pointerStrength = 0;
    let pointerX = 0;
    let pointerY = 0;
    let pulse = 0;
    let imageReady = false;
    let imageBitmap: ImageBitmap | null = null;
    let imageData: ImageData | null = null;
    let imageDataWidth = 0;
    let imageDataHeight = 0;
    let pointerListenersBound = false;
    let fragmentColor = 'rgba(244, 228, 193, 0.94)';
    let dustColor = 'rgba(255, 214, 150, 0.4)';
    let glowColor = 'rgba(255, 214, 150, 0.18)';
    let glowRgb = '255, 214, 150';
    let isVisible = true;
    let isDestroyed = false;

    const MAX_FRAGMENTS = 84;
    const FRAGMENT_IDLE_MS = 220;
    const fragments = Array.from({ length: MAX_FRAGMENTS }, () => ({
      active: false,
      x: 0,
      y: 0,
      originX: 0,
      originY: 0,
      vx: 0,
      vy: 0,
      size: 0,
      rotation: 0,
      rotationVelocity: 0,
      life: 0,
      maxLife: 0,
      alpha: 0,
      color: '',
      drift: 0,
    }));

    const readEdgeBand = () => {
      const bandValue = Number.parseFloat(getComputedStyle(root).getPropertyValue('--hero-shatter-band'));
      return Number.isFinite(bandValue) ? bandValue : 40;
    };

    const updatePalette = () => {
      const glowRgbValue = getComputedStyle(root).getPropertyValue('--hero-shatter-glow-rgb').trim() || '255 214 150';
      const fragmentRgbValue = getComputedStyle(root).getPropertyValue('--hero-shatter-fragment-rgb').trim() || '244 228 193';
      glowRgb = glowRgbValue.split(/\s+/).join(', ');
      const fragmentRgb = fragmentRgbValue.split(/\s+/).join(', ');
      fragmentColor = `rgba(${fragmentRgb}, 0.82)`;
      dustColor = `rgba(${glowRgb}, 0.22)`;
      glowColor = `rgba(${glowRgb}, 0.1)`;
    };

    const getImageRect = () => {
      const bounds = root.getBoundingClientRect();
      const naturalWidth = image.naturalWidth || width;
      const naturalHeight = image.naturalHeight || height;
      const scale = Math.max(bounds.width / naturalWidth, bounds.height / naturalHeight);
      const renderedWidth = naturalWidth * scale;
      const renderedHeight = naturalHeight * scale;
      const objectPosition = getComputedStyle(image).objectPosition || '50% 50%';
      const [positionXRaw = '50%', positionYRaw = '50%'] = objectPosition.split(/\s+/);
      const parsePosition = (value: string) => {
        if (value.endsWith('%')) return Number.parseFloat(value) / 100;
        if (value === 'left' || value === 'top') return 0;
        if (value === 'right' || value === 'bottom') return 1;
        if (value === 'center') return 0.5;
        return 0.5;
      };

      const offsetX = (bounds.width - renderedWidth) * parsePosition(positionXRaw);
      const offsetY = (bounds.height - renderedHeight) * parsePosition(positionYRaw);

      return {
        x: offsetX,
        y: offsetY,
        width: renderedWidth,
        height: renderedHeight,
      };
    };

    const sampleColor = (sourceX: number, sourceY: number) => {
      if (!imageData || !imageDataWidth || !imageDataHeight) {
        return fragmentColor;
      }

      const pixelX = Math.max(0, Math.min(imageDataWidth - 1, Math.round(sourceX)));
      const pixelY = Math.max(0, Math.min(imageDataHeight - 1, Math.round(sourceY)));
      const pixelIndex = (pixelY * imageDataWidth + pixelX) * 4;
      const red = imageData.data[pixelIndex] ?? 244;
      const green = imageData.data[pixelIndex + 1] ?? 228;
      const blue = imageData.data[pixelIndex + 2] ?? 193;
      return `rgba(${red}, ${green}, ${blue}, 0.92)`;
    };

    const mapCanvasToImage = (canvasX: number, canvasY: number) => {
      const imageRect = getImageRect();
      const relativeX = imageRect.width ? (canvasX - imageRect.x) / imageRect.width : 0.5;
      const relativeY = imageRect.height ? (canvasY - imageRect.y) / imageRect.height : 0.5;
      return {
        x: relativeX * imageDataWidth,
        y: relativeY * imageDataHeight,
      };
    };

    const isNearEdge = (x: number, y: number) => (
      x <= edgeBand || x >= width - edgeBand || y <= edgeBand || y >= height - edgeBand
    );

    const deactivateFragment = (fragment: typeof fragments[number]) => {
      fragment.active = false;
      fragment.life = 0;
      fragment.alpha = 0;
    };

    const spawnFragment = (originX: number, originY: number, intensity: number) => {
      const fragment = fragments.find((item) => !item.active);
      if (!fragment) return;

      const angle = Math.random() * Math.PI * 2;
      const radialBias = Math.max(0.48, intensity);
      const offset = Math.random() * edgeBand * 0.04;
      const mappedPoint = mapCanvasToImage(originX, originY);

      fragment.active = true;
      fragment.originX = originX;
      fragment.originY = originY;
      fragment.x = originX + Math.cos(angle) * offset;
      fragment.y = originY + Math.sin(angle) * offset;
      fragment.vx = (Math.random() - 0.5) * 0.2 + Math.cos(angle) * (0.24 + radialBias * 0.7);
      fragment.vy = (Math.random() - 0.5) * 0.2 + Math.sin(angle) * (0.22 + radialBias * 0.62);
      fragment.size = 0.9 + Math.random() * 1.5 + radialBias * 0.95;
      fragment.rotation = Math.random() * Math.PI;
      fragment.rotationVelocity = (Math.random() - 0.5) * 0.12;
      fragment.maxLife = 9 + Math.random() * 6;
      fragment.life = fragment.maxLife;
      fragment.alpha = 0.24 + Math.random() * 0.14;
      fragment.drift = 0.88 + Math.random() * 0.035;
      fragment.color = imageReady ? sampleColor(mappedPoint.x, mappedPoint.y) : fragmentColor;
    };

    const emitShatter = (eventX: number, eventY: number, deltaX: number, deltaY: number) => {
      if (reducedMotion || !isNearEdge(eventX, eventY)) return;

      const movement = Math.min(1, Math.hypot(deltaX, deltaY) / 24);
      const edgeAffinity = 1 - Math.min(
        Math.min(eventX, width - eventX, eventY, height - eventY) / Math.max(edgeBand, 1),
        1,
      );
      const spawnCount = Math.max(1, Math.round(1 + movement * 1.4 + edgeAffinity * 1.2));

      for (let index = 0; index < spawnCount; index += 1) {
        const scatter = Math.random() * edgeBand * 0.05;
        const scatterAngle = Math.random() * Math.PI * 2;
        spawnFragment(
          eventX + Math.cos(scatterAngle) * scatter,
          eventY + Math.sin(scatterAngle) * scatter,
          Math.max(movement, edgeAffinity),
        );
      }
    };

    const drawStaticEdgeDust = () => {
      const corners = [
        { x: edgeBand * 0.8, y: edgeBand * 0.8 },
        { x: width - edgeBand * 0.8, y: edgeBand * 0.92 },
        { x: width - edgeBand * 0.82, y: height - edgeBand * 0.82 },
        { x: edgeBand * 0.78, y: height - edgeBand * 0.9 },
      ];

      context.fillStyle = dustColor;
      corners.forEach((corner, cornerIndex) => {
        const count = 4 + cornerIndex;
        for (let index = 0; index < count; index += 1) {
          const distance = Math.random() * edgeBand * 0.58;
          const angle = (Math.PI / 2) * cornerIndex + Math.random() * 0.9;
          const x = corner.x + Math.cos(angle) * distance;
          const y = corner.y + Math.sin(angle) * distance;
          context.globalAlpha = 0.14 + Math.random() * 0.12;
          context.beginPath();
          context.arc(x, y, 0.8 + Math.random() * 1.4, 0, Math.PI * 2);
          context.fill();
        }
      });
    };

    const drawGlow = () => {
      const imageRect = getImageRect();
      const glowAlpha = 0.018 + pointerStrength * 0.022;
      const edgeGradient = context.createRadialGradient(pointerX, pointerY, 0, pointerX, pointerY, edgeBand * 1.1);
      edgeGradient.addColorStop(0, `rgba(${glowRgb}, ${glowAlpha})`);
      edgeGradient.addColorStop(1, `rgba(${glowRgb}, 0)`);
      context.fillStyle = edgeGradient;
      context.globalAlpha = 0.18;
      context.fillRect(0, 0, width, height);

      const perimeterGlow = context.createLinearGradient(imageRect.x, imageRect.y, imageRect.x + imageRect.width, imageRect.y + imageRect.height);
      perimeterGlow.addColorStop(0, `rgba(${glowRgb}, 0.012)`);
      perimeterGlow.addColorStop(0.5, `rgba(${glowRgb}, 0)`);
      perimeterGlow.addColorStop(1, `rgba(${glowRgb}, 0.016)`);
      context.strokeStyle = perimeterGlow;
      context.globalAlpha = 0.1 + pointerStrength * 0.04;
      context.lineWidth = 1;
      context.strokeRect(0.5, 0.5, Math.max(width - 1, 0), Math.max(height - 1, 0));
      context.globalAlpha = 1;
    };

    const drawFragment = (fragment: typeof fragments[number]) => {
      const lifeRatio = fragment.maxLife ? fragment.life / fragment.maxLife : 0;
      const shardSize = fragment.size * (0.72 + lifeRatio * 0.4);

      context.save();
      context.translate(fragment.x, fragment.y);
      context.rotate(fragment.rotation);
      context.globalAlpha = fragment.alpha * lifeRatio;
      context.fillStyle = fragment.color;
      context.beginPath();
      context.moveTo(0, -shardSize);
      context.lineTo(shardSize * 0.85, shardSize * 0.2);
      context.lineTo(0, shardSize);
      context.lineTo(-shardSize * 0.55, shardSize * 0.08);
      context.closePath();
      context.fill();
      context.restore();

      context.globalAlpha = fragment.alpha * lifeRatio * 0.22;
      context.fillStyle = dustColor;
      context.beginPath();
      context.arc(fragment.originX, fragment.originY, Math.max(0.5, shardSize * 0.24), 0, Math.PI * 2);
      context.fill();
      context.globalAlpha = 1;
    };

    const drawFrame = (time = performance.now()) => {
      context.clearRect(0, 0, width, height);

      pulse += (pointerInside ? 0.05 : 0.02) + pointerStrength * 0.015;
      pointerStrength += ((pointerInside ? 1 : 0) - pointerStrength) * 0.08;

      drawGlow();

      if (reducedMotion) {
        drawStaticEdgeDust();
      }

      fragments.forEach((fragment) => {
        if (!fragment.active) return;

        fragment.life -= 1;
        if (fragment.life <= 0) {
          deactivateFragment(fragment);
          return;
        }

        fragment.vx *= fragment.drift;
        fragment.vy *= fragment.drift;
        fragment.x += fragment.vx;
        fragment.y += fragment.vy;
        fragment.rotation += fragment.rotationVelocity;
        fragment.alpha *= 0.97;

        if (!isNearEdge(fragment.originX, fragment.originY) || fragment.x < -24 || fragment.x > width + 24 || fragment.y < -24 || fragment.y > height + 24) {
          deactivateFragment(fragment);
          return;
        }

        drawFragment(fragment);
      });

      context.globalAlpha = 0.12 + pointerStrength * 0.08;
      context.strokeStyle = dustColor;
      context.lineWidth = 1;
      context.setLineDash([2, 12]);
      context.lineDashOffset = -pulse * 6;
      context.strokeRect(edgeBand * 0.18, edgeBand * 0.18, width - edgeBand * 0.36, height - edgeBand * 0.36);
      context.setLineDash([]);
      context.globalAlpha = 1;
    };

    const render = (time: number) => {
      drawFrame(time);
      const hasActiveFragments = fragments.some((fragment) => fragment.active);
      const shouldKeepAnimating = isVisible && (pointerInside || pointerStrength > 0.02 || hasActiveFragments);

      if (shouldKeepAnimating) {
        animationFrameId = window.requestAnimationFrame(render);
      } else {
        animationFrameId = 0;
      }
    };

    const startRenderLoop = () => {
      if (animationFrameId) return;
      animationFrameId = window.requestAnimationFrame(render);
    };

    const resizeCanvas = () => {
      const bounds = root.getBoundingClientRect();
      width = Math.max(bounds.width, 1);
      height = Math.max(bounds.height, 1);
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      edgeBand = Math.min(readEdgeBand(), width * 0.22, height * 0.22);
      updatePalette();
      canvas.width = Math.round(width * dpr);
      canvas.height = Math.round(height * dpr);
      canvas.style.width = `${width}px`;
      canvas.style.height = `${height}px`;
      context.setTransform(dpr, 0, 0, dpr, 0, 0);
      pointerX = width * 0.5;
      pointerY = height * 0.5;
      fragments.forEach(deactivateFragment);
      drawFrame();
    };

    const handleResize = () => {
      window.cancelAnimationFrame(resizeFrameId);
      resizeFrameId = window.requestAnimationFrame(() => {
        resizeCanvas();
      });
    };

    const handlePointerMove = (event: PointerEvent) => {
      const bounds = root.getBoundingClientRect();
      const nextX = event.clientX - bounds.left;
      const nextY = event.clientY - bounds.top;
      const deltaX = nextX - pointerX;
      const deltaY = nextY - pointerY;

      pointerInside = true;
      pointerX = nextX;
      pointerY = nextY;
      emitShatter(nextX, nextY, deltaX, deltaY);
      window.clearTimeout(idleTimer);
      idleTimer = window.setTimeout(() => {
        pointerInside = false;
      }, FRAGMENT_IDLE_MS);
      startRenderLoop();
    };

    const handlePointerLeave = () => {
      pointerInside = false;
      window.clearTimeout(idleTimer);
      startRenderLoop();
    };

    const setVisibility = (nextVisible: boolean) => {
      isVisible = nextVisible;
      if (isVisible) {
        startRenderLoop();
        return;
      }

      pointerInside = false;
      pointerStrength = 0;
      window.clearTimeout(idleTimer);
      window.cancelAnimationFrame(animationFrameId);
      animationFrameId = 0;
      drawFrame();
    };

    const bindPointerListeners = () => {
      if (pointerListenersBound || reducedMotion) return;
      root.addEventListener('pointermove', handlePointerMove);
      root.addEventListener('pointerleave', handlePointerLeave);
      pointerListenersBound = true;
    };

    const unbindPointerListeners = () => {
      if (!pointerListenersBound) return;
      root.removeEventListener('pointermove', handlePointerMove);
      root.removeEventListener('pointerleave', handlePointerLeave);
      pointerListenersBound = false;
    };

    const prepareImageData = async () => {
      if (!image.complete || !image.naturalWidth || !image.naturalHeight) return;

      try {
        imageBitmap?.close();
        imageBitmap = await createImageBitmap(image);
        const sampleWidth = Math.max(48, Math.round(imageBitmap.width * 0.18));
        const sampleHeight = Math.max(48, Math.round(imageBitmap.height * 0.18));
        const sampleCanvas = document.createElement('canvas');
        sampleCanvas.width = sampleWidth;
        sampleCanvas.height = sampleHeight;
        const sampleContext = sampleCanvas.getContext('2d', { willReadFrequently: true });
        if (!sampleContext) return;
        sampleContext.drawImage(imageBitmap, 0, 0, sampleWidth, sampleHeight);
        imageData = sampleContext.getImageData(0, 0, sampleWidth, sampleHeight);
        imageDataWidth = sampleWidth;
        imageDataHeight = sampleHeight;
        imageReady = true;
      } catch {
        imageData = null;
        imageDataWidth = 0;
        imageDataHeight = 0;
        imageReady = false;
        console.warn('Hero shatter effect image sampling failed. Falling back to default fragment colors.');
      }
    };

    const handleMotionChange = (event: MediaQueryListEvent) => {
      reducedMotion = event.matches;
      pointerInside = false;
      pointerStrength = 0;
      window.cancelAnimationFrame(animationFrameId);
      animationFrameId = 0;
      window.clearTimeout(idleTimer);
      fragments.forEach(deactivateFragment);
      if (reducedMotion) {
        unbindPointerListeners();
      } else {
        bindPointerListeners();
      }
      resizeCanvas();
    };

    const initializeImage = () => {
      prepareImageData().finally(() => {
        if (isDestroyed) return;
        drawFrame();
        startRenderLoop();
      });
    };

    resizeCanvas();
    bindPointerListeners();
    window.addEventListener('resize', handleResize);

    let visibilityObserver: IntersectionObserver | null = null;
    if (typeof IntersectionObserver !== 'undefined') {
      visibilityObserver = new IntersectionObserver(
        ([entry]) => {
          setVisibility(entry?.isIntersecting ?? true);
        },
        { threshold: 0.05 }
      );
      visibilityObserver.observe(root);
    }

    if (image.complete && image.naturalWidth) {
      initializeImage();
    } else {
      image.addEventListener('load', initializeImage, { once: true });
    }

    if ('addEventListener' in motionQuery) {
      motionQuery.addEventListener('change', handleMotionChange);
    } else {
      legacyMotionQuery.addListener?.(handleMotionChange);
    }

    return () => {
      isDestroyed = true;
      window.cancelAnimationFrame(animationFrameId);
      window.cancelAnimationFrame(resizeFrameId);
      window.clearTimeout(idleTimer);
      unbindPointerListeners();
      visibilityObserver?.disconnect();
      window.removeEventListener('resize', handleResize);
      image.removeEventListener('load', initializeImage);
      if ('removeEventListener' in motionQuery) {
        motionQuery.removeEventListener('change', handleMotionChange);
      } else {
        legacyMotionQuery.removeListener?.(handleMotionChange);
      }
      imageBitmap?.close();
      context.clearRect(0, 0, width, height);
    };
  }

  function initLanding() {
    if (landingInitialized) return;

    setLandingHeaderVisibility(false);

    const landing = document.getElementById('landing');
    if (!landing) return;

    landingInitialized = true;

    const visual = landing.querySelector<HTMLElement>('.landing-visual');
    landingCleanup = visual ? createHeroImageShatter(visual) : null;
    typewriterCleanup = initLandingTypewriter(landing);

    let observer: IntersectionObserver | null = null;

    // Hide header when landing is visible
    if (typeof IntersectionObserver !== 'undefined') {
      observer = new IntersectionObserver(
        ([entry]) => {
          setLandingHeaderVisibility(entry.isIntersecting);
        },
        { threshold: 0.3 }
      );
      observer.observe(landing);
    }

    // Smooth scroll for the button
    const btn = landing.querySelector('a[href="#selected-work"]');
    const handleScrollClick = (e: Event) => {
      e.preventDefault();
      const behavior = window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth';
      document.getElementById('selected-work')?.scrollIntoView({ behavior });
    };
    btn?.addEventListener('click', handleScrollClick);

    document.addEventListener('astro:before-swap', () => {
      landingInitialized = false;
      setLandingHeaderVisibility(false);
      observer?.disconnect();
      landingCleanup?.();
      landingCleanup = null;
      typewriterCleanup?.();
      typewriterCleanup = null;
      btn?.removeEventListener('click', handleScrollClick);
      document.removeEventListener('astro:after-swap', initLanding);
    }, { once: true });
  }

  document.removeEventListener('astro:after-swap', initLanding);
  document.addEventListener('astro:after-swap', initLanding);
  initLanding();
</script>

